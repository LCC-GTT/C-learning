//解决约瑟夫循环问题
#include<stdio.h>
int main()
{
	int n,k=0,i=0,c;
	scanf("%d",&n);
	int f[n];
	for(i=0;i<n;i++)
	{
		f[i]=i+1;
	}
	i=0;
	c=n;
	while(c>1)
	{
		if(f[i]!=0)
		k++;
		if(k==3)
		{
			f[i]=0;
			k=0;
			c--;
		}
		i=(i+1)%n;
	}
	for(i=0;i<n;i++)
	{
		if(f[i]!=0)
		{
			printf("%d",f[i]);
			break;
		}
	}
	return 0;
}
